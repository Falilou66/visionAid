<?xml version="1.0" encoding="utf-8"?>
<!--
  We only need to know which app is in the foreground; the screen text is read
  on demand. So we subscribe to window *state* changes only (rare), NOT content
  changes (which Chrome fires continuously and which caused main-thread ANRs).
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="500"
    android:description="@string/accessibility_service_description" />
